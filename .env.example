# ──────────────────────────────────────────────────────────────────────────
# Creator Asset Marketplace — Environment Configuration
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# All variables are validated at boot by src/config/env.ts (Zod). The process
# will refuse to start if anything is missing or malformed.
# ──────────────────────────────────────────────────────────────────────────

# Runtime
NODE_ENV=development
PORT=8080
API_PREFIX=/api/v1

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/creator_asset_marketplace

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Logging — one of: error, warn, info, http, debug
LOG_LEVEL=debug

# Cookies / signing secret
COOKIE_SECRET=replace-with-a-long-random-string

# Web frontend URL — used to build password-reset / email-verify links
WEB_APP_URL=http://localhost:3000

# JWT — generate strong unique secrets, e.g. `openssl rand -base64 48`
JWT_ACCESS_SECRET=replace-with-a-long-random-access-secret-min-32-chars
JWT_REFRESH_SECRET=replace-with-a-long-random-refresh-secret-min-32-chars
JWT_ACCESS_TTL_MS=900000
JWT_REFRESH_TTL_MS=604800000

# Google OAuth — optional. Leave blank to disable Google sign-in.
GOOGLE_CLIENT_ID=

# Email / SMTP — optional. Leave SMTP_HOST blank to use an auto Ethereal test
# inbox in development (preview links are logged). Examples:
#   Gmail:    SMTP_HOST=smtp.gmail.com    SMTP_PORT=465 SMTP_SECURE=true
#   SendGrid: SMTP_HOST=smtp.sendgrid.net SMTP_PORT=587 SMTP_USER=apikey
#   Mailtrap: SMTP_HOST=sandbox.smtp.mailtrap.io SMTP_PORT=587
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=Creator Asset Marketplace <no-reply@creatorassets.dev>

# Stripe (Connect) — optional. Leave STRIPE_SECRET_KEY blank to disable payments.
#   STRIPE_WEBHOOK_SECRET: from `stripe listen` or the Dashboard webhook endpoint.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PLATFORM_COMMISSION_PERCENT=10
STRIPE_CONNECT_COUNTRY=US
